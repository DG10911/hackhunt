# Copy this file to ".env" and fill in your values. Never commit the real .env.

# ---- Public URL of your app (used for OAuth redirect + email links) ----
APP_URL=http://localhost:5050

# ---- Google Sign-In (frontend) ----
# Paste the Client ID into GOOGLE_CLIENT_ID at the top of frontend/index.html too.
# (Google uses a client-side flow, so no secret is needed here.)

# ---- GitHub OAuth (backend) ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- Email reminders (SMTP) ----
# Gmail: host smtp.gmail.com, port 587, user=your@gmail.com, pass=App Password
# Resend: host smtp.resend.com, port 465, user=resend, pass=API key
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
REMIND_DAYS=3
# protects POST /api/run-reminders so only you can trigger it
REMINDER_TOKEN=change-me

# ---- Database (optional; default is local SQLite hackhunt.db) ----
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
